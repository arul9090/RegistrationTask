MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.example.mongodb.net/?appName=Cluster0
MONGO_DB=skillrank_db
SECRET_KEY=change-this-session-secret
JWT_SECRET=change-this-jwt-secret

# Google OAuth
# Google Cloud Console redirect URI:
# http://localhost:5000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP mailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Optional seed admin overrides
ADMIN_EMAIL=admin@skillrank.com
ADMIN_PASS=admin123
